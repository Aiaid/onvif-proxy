{
  "name": "onvif-proxy-ui",
  "version": "0.0.0",
  "private": true,
  "description": "ONVIF Proxy management UI (Preact + TSX, bundled by esbuild).",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "esbuild src/main.tsx --bundle --minify --format=esm --target=es2020 --jsx=automatic --jsx-import-source=preact --outfile=../static/dist/app.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "preact": "^10.26.0",
    "typescript": "^5.9.0"
  }
}
